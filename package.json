{
  "name": "obsidian-llm-cli-bridge",
  "version": "2.18.0",
  "description": "Bridge Obsidian to local Claude Code / Claude SDK agents.",
  "main": "main.js",
  "scripts": {
    "dev": "node scripts/build-styles.mjs && node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node scripts/check-codex-schema.mjs && node scripts/build-styles.mjs && node esbuild.config.mjs production",
    "build:styles": "node scripts/build-styles.mjs",
    "smoke:codex-app-server": "node scripts/codex-app-server-smoke.mjs",
    "smoke:codex-managed-runtime": "node scripts/codex-managed-runtime-smoke.mjs",
    "smoke:codex-runtime-install-default-package": "node scripts/codex-runtime-install-default-package-smoke.mjs",
    "smoke:codex-runtime-install-download": "node scripts/codex-runtime-install-download-smoke.mjs",
    "smoke:codex-managed-first-run": "node scripts/codex-managed-first-run-smoke.mjs",
    "smoke:pi-sdk": "node scripts/pi-sdk-smoke.mjs",
    "smoke:user-package": "node scripts/user-package-smoke.mjs",
    "smoke:tool-presentation": "node scripts/tool-presentation-smoke.mjs",
    "smoke:ui-01": "node scripts/ui-01-smoke.mjs",
    "smoke:ui-02": "node scripts/ui-02-smoke.mjs",
    "smoke:ui-03": "node scripts/ui-03-smoke.mjs",
    "smoke:f03": "node scripts/f03-smoke.mjs",
    "smoke:ui-package": "node scripts/ui-smoke-package.mjs",
    "codex:schema": "node scripts/generate-codex-schema.mjs",
    "codex:schema:check": "node scripts/check-codex-schema.mjs",
    "release": "node scripts/build-release.mjs",
    "release:offline": "node scripts/build-release.mjs --offline-runtime",
    "build:user-package": "node scripts/build-user-package.mjs",
    "build:user-package:offline": "node scripts/build-user-package.mjs --offline-runtime",
    "build:user-package:smoke": "node scripts/build-user-package.mjs && node scripts/user-package-smoke.mjs",
    "report:runtime-distribution": "node scripts/generate-runtime-distribution-report.mjs",
    "report:codex-capability-matrix": "node scripts/generate-codex-capability-matrix.mjs",
    "report:codex-timeline-smoke": "node scripts/generate-codex-timeline-smoke.mjs",
    "smoke:codex-real-protocol-capability": "node scripts/codex-real-protocol-capability-smoke.mjs",
    "smoke:codex-real-obsidian-runtime-ux": "node scripts/codex-real-obsidian-runtime-ux-smoke.mjs",
    "release:receipt": "node scripts/generate-release-receipt.mjs"
  },
  "keywords": [
    "obsidian",
    "claude-code",
    "codex",
    "cli",
    "bridge"
  ],
  "author": "Ye_Luo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.20.2",
    "obsidian": "^1.4.16",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5"
  },
  "optionalDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3"
  },
  "llmCliBridge": {
    "portableBackend": {
      "providerId": "pi-sdk",
      "packageName": "@earendil-works/pi-coding-agent",
      "installHint": "npm install --ignore-scripts @earendil-works/pi-coding-agent",
      "minVersion": "0.80.3"
    }
  }
}
