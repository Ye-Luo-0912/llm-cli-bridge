{
  "name": "obsidian-llm-cli-bridge",
  "version": "2.16.0",
  "description": "Bridge Obsidian to local Claude Code / Claude SDK agents.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node scripts/run-tests.mjs",
    "test:unit": "node scripts/run-tests.mjs --unit",
    "test:process": "node scripts/run-tests.mjs --process",
    "test:claude": "node scripts/run-tests.mjs --claude",
    "test:integration": "node scripts/run-tests.mjs --integration",
    "test:codex-app-server": "node scripts/codex-app-server-smoke.mjs",
    "smoke:codex-app-server": "node scripts/codex-app-server-smoke.mjs",
    "smoke:pi-sdk": "node scripts/pi-sdk-smoke.mjs",
    "test:summary": "node scripts/generate-test-summary.mjs",
    "codex:schema": "node scripts/generate-codex-schema.mjs",
    "release": "node scripts/build-release.mjs"
  },
  "keywords": [
    "obsidian",
    "claude-code",
    "codex",
    "cli",
    "bridge"
  ],
  "author": "Ye_Luo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.20.2",
    "obsidian": "^1.4.16",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5"
  },
  "optionalDependencies": {
    "@earendil-works/pi-coding-agent": "^0.0.27"
  },
  "llmCliBridge": {
    "portableBackend": {
      "providerId": "pi-sdk",
      "packageName": "@earendil-works/pi-coding-agent",
      "installHint": "npm install --ignore-scripts @earendil-works/pi-coding-agent",
      "minVersion": "0.0.27"
    }
  }
}
