# Build output
main.js
*.js.map
# TypeScript compilation artifacts in src/ (src is .ts-only; .js are tsc outputs)
src/**/*.js

# Dependencies
node_modules/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/

# Test temp bundles
.test-*.mjs
.git-commit-msg.txt
temp-debug*/

# Build distribution（本地构建产物，不入库）
dist/

# Runtime state（包含 token / bridge.json / 日志 / 状态 / outbox）
.llm-bridge/

# 本地敏感文件（env / token / key / secret / credential）
*.env
.env.*
**/*token*
**/*secret*
**/*credential*
**/credentials.json
**/.bridge-token

# V20: runtime provider 本地真相源（含 API Key，不随 Vault 同步，不提交 Git）
private/

# Obsidian workspace 临时状态（仅当仓库内含 vault 时生效）
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json

# Release 打包产物（不入库，仅本地生成）
release/

# Codex managed runtime artifacts（由 pinned manifest/source 安装，不进代码提交）
.tmp/
.tmp-*.txt
.tmp-*
src/runtime/providers/codex-managed-app-server/runtime/win32-x64/codex.exe
src/runtime/providers/codex-managed-app-server/runtime/win32-arm64/codex.exe
src/runtime/providers/codex-managed-app-server/runtime/linux-x64/codex
src/runtime/providers/codex-managed-app-server/runtime/linux-arm64/codex
src/runtime/providers/codex-managed-app-server/runtime/darwin-x64/codex
src/runtime/providers/codex-managed-app-server/runtime/darwin-arm64/codex
